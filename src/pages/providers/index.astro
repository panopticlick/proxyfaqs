---
export const prerender = true;

import Base from '../../layouts/Base.astro';
import ProviderCard from '../../components/ProviderCard.astro';
import { assertBuildDataNonEmpty, handleBuildDataError } from '../../lib/build-data';
import {
  getProviderDisplayName,
  getProviderFallbackDescription,
  getTopProviderEvidence,
  methodologyHighlights,
} from '../../lib/content-intelligence';
import { getProviders, type Provider } from '../../lib/supabase';
import { generateCollectionPageSchema } from '../../lib/utils';
import { env } from '../../lib/env';

let providers: Provider[] = [];

try {
  providers = await getProviders();
} catch (error) {
  handleBuildDataError('providers index data fetch', error);
}

assertBuildDataNonEmpty('providers index providers', providers.length);

const siteUrl = env.SITE;
const pageUrl = `${siteUrl}/providers`;
const editorialShortlist = getTopProviderEvidence();

const jsonLd = [
  generateCollectionPageSchema({
    name: 'Proxy Provider Reviews - ProxyFAQs',
    description: 'Browse provider profiles, product-fit notes, and research-backed comparison guidance for proxy and scraping vendors.',
    url: pageUrl,
    itemCount: providers.length,
    items: providers.slice(0, 10).map(provider => ({
      name: getProviderDisplayName(provider),
      url: `${siteUrl}/providers/${provider.slug}`,
    })),
  }),
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: 'Proxy provider profiles',
    description: 'Browse proxy and scraping provider profiles by product fit and research notes.',
    itemListElement: providers.slice(0, 10).map((provider, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      item: {
        '@type': 'Thing',
        name: getProviderDisplayName(provider),
        description: getProviderFallbackDescription(provider) || provider.description || undefined,
        url: `${siteUrl}/providers/${provider.slug}`,
      },
    })),
  },
];
---

<Base
  title="Proxy Provider Reviews"
  description="Browse provider profiles, product-fit notes, and research-backed comparison guidance for proxy and scraping vendors."
  canonicalUrl={pageUrl}
  jsonLd={jsonLd}
>
  <div class="bg-secondary-50 min-h-screen">
    <!-- Header -->
    <section class="bg-gradient-to-b from-primary-50 to-white py-12">
      <div class="container-custom">
        <div class="text-center mb-8">
          <h1 class="text-3xl md:text-4xl font-bold text-secondary-900 mb-4">
            Proxy Provider Reviews
          </h1>
          <p class="text-lg text-secondary-600 max-w-2xl mx-auto">
            Use this page to browse provider profiles by job fit, not by hype. Proxy networks,
            scraping APIs, and actor-style tooling are compared as separate product shapes.
          </p>
        </div>

        <div class="flex flex-wrap justify-center gap-2">
          <span class="category-pill bg-primary-100 text-primary-700">Residential</span>
          <span class="category-pill">Datacenter</span>
          <span class="category-pill">Mobile</span>
          <span class="category-pill">ISP</span>
          <span class="category-pill">Scraping APIs</span>
        </div>
      </div>
    </section>

    <section class="py-8 bg-white border-b border-secondary-100">
      <div class="container-custom">
        <div class="grid gap-6 lg:grid-cols-[1.3fr,1fr]">
          <div class="card">
            <h2 class="text-2xl font-bold text-secondary-900 mb-4">How to read these provider profiles</h2>
            <ul class="space-y-3 text-secondary-600">
              {methodologyHighlights.map((item) => (
                <li class="flex items-start gap-2">
                  <span class="text-primary-600 mt-1">•</span>
                  <span>{item}</span>
                </li>
              ))}
            </ul>
          </div>

          <div class="card">
            <h2 class="text-2xl font-bold text-secondary-900 mb-4">Editorial shortlist</h2>
            <div class="space-y-3">
              {editorialShortlist.map((item) => (
                <a
                  href={`/providers/${item.slug}`}
                  class="block rounded-lg border border-secondary-200 bg-secondary-50 px-4 py-3 hover:border-primary-300"
                >
                  <div class="font-semibold text-secondary-900">{item.displayName}</div>
                  <div class="text-sm text-secondary-600 mt-1">
                    {item.bestFor[0]}
                  </div>
                  <div class="text-xs text-secondary-500 mt-2">
                    Reviewed {item.lastReviewed}
                  </div>
                </a>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Provider Grid -->
    <section class="py-8">
      <div class="container-custom">
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {providers.map((provider) => <ProviderCard provider={provider} />)}
        </div>

        {
          providers.length === 0 && (
            <div class="text-center py-12">
              <div class="w-16 h-16 rounded-full bg-secondary-100 flex items-center justify-center mx-auto mb-4">
                <svg
                  class="w-8 h-8 text-secondary-400"
                  fill="none"
                  stroke="currentColor"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"
                  />
                </svg>
              </div>
              <h2 class="text-xl font-semibold text-secondary-900 mb-2">No providers found</h2>
              <p class="text-secondary-600">Provider data is being imported. Check back soon!</p>
            </div>
          )
        }
      </div>
    </section>

    <!-- Affiliate Disclosure -->
    <section class="py-8 bg-white">
      <div class="container-custom">
        <div class="max-w-3xl mx-auto text-center">
          <h2 class="text-xl font-semibold text-secondary-900 mb-4">How We Make Money</h2>
          <p class="text-secondary-600 text-sm">
            Some links on this page are affiliate links. This means we may earn a commission if you
            sign up through our links, at no extra cost to you. This helps us maintain the site and
            provide comparison research and editorial guidance. Recommendations are based on the
            site's current research layer, product-fit notes, and dated evidence, not on universal
            scores.
          </p>
        </div>
      </div>
    </section>
  </div>
</Base>
