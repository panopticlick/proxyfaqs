---
export const prerender = true;

import AffiliateDisclosure from '../../components/AffiliateDisclosure.astro';
import Base from '../../layouts/Base.astro';
import { getProvider, getAllProviderSlugs, getProviders, type Provider } from '../../lib/supabase';
import {
  getProviderDisplayName,
  getProviderCons,
  getProviderEvidence,
  getProviderFallbackDescription,
  getProviderPros,
  hasSubstantiveReview,
  shouldShowEditorialRating,
} from '../../lib/content-intelligence';
import { generateBreadcrumbSchema, generateProductSchema } from '../../lib/utils';
import { env } from '../../lib/env';

export async function getStaticPaths() {
  try {
    const slugs = await getAllProviderSlugs();
    return slugs.map((slug) => ({ params: { slug } }));
  } catch (error) {
    const err = error instanceof Error ? error : new Error(String(error));
    console.warn('Could not fetch provider slugs (database may not be set up yet):', err.message);
    return [];
  }
}

const { slug } = Astro.params;

let provider: Provider | null = null;
let otherProviders: Provider[] = [];

try {
  [provider, otherProviders] = await Promise.all([getProvider(slug), getProviders()]);
  otherProviders = otherProviders.filter((p) => p.slug !== slug).slice(0, 4);
} catch (error) {
  console.error('Error fetching provider:', error);
}

if (!provider) {
  return Astro.redirect('/404');
}

const siteUrl = env.SITE;
const pageUrl = `${siteUrl}/providers/${slug}`;

const editorial = getProviderEvidence(provider);
const displayName = getProviderDisplayName(provider);
const rawDescription = provider.description?.trim() || '';
const isGenericDescription =
  rawDescription.includes('professional proxy service provider') ||
  rawDescription.includes('Product coverage, pricing, and review notes should be verified');
const fallbackDescription = getProviderFallbackDescription(provider);
const pageDescription =
  rawDescription && !isGenericDescription && rawDescription.length >= 120
    ? rawDescription
    : fallbackDescription ||
      `Research-backed profile for ${displayName}: product fit, watchouts, and comparison notes.`;
const hasReviewHtml =
  typeof provider.review_html === 'string' &&
  provider.review_html.replace(/<[^>]*>/g, '').trim().length >= 500;
const substantiveReview = hasSubstantiveReview(provider);
const canShowRating = shouldShowEditorialRating(provider) && hasReviewHtml;
const stars = canShowRating && provider.rating ? Math.round(provider.rating) : 0;
const shouldNoindex = !(substantiveReview || editorial);
const providerPros = getProviderPros(provider);
const providerCons = getProviderCons(provider);

const hasAffiliateLink = !!provider.affiliate_url;

const rawStartingPrice =
  provider.pricing && typeof provider.pricing === 'object'
    ? provider.pricing['starting_price']
    : undefined;
const formatPriceRange = (value: unknown) => {
  if (typeof value === 'number') {
    return `$${value}+`;
  }

  if (typeof value !== 'string') {
    return undefined;
  }

  const trimmed = value.trim();

  if (!trimmed) {
    return undefined;
  }

  if (/contact/i.test(trimmed)) {
    return trimmed;
  }

  if (/^\$\d/.test(trimmed)) {
    return trimmed;
  }

  if (/^\d+(\.\d+)?$/.test(trimmed)) {
    return `$${trimmed}+`;
  }

  if (/^\d/.test(trimmed)) {
    return `$${trimmed}`;
  }

  return trimmed;
};
const priceRange =
  formatPriceRange(rawStartingPrice);

const jsonLd: object[] = [
  generateBreadcrumbSchema([
    { name: 'Home', url: siteUrl },
    { name: 'Providers', url: `${siteUrl}/providers` },
    { name: displayName, url: pageUrl },
  ]),
];

if (!shouldNoindex) {
  jsonLd.push(
    generateProductSchema({
      name: displayName,
      description: pageDescription,
      url: pageUrl,
      logo: provider.logo_url ?? undefined,
      rating: canShowRating ? provider.rating ?? undefined : undefined,
      reviewCount: canShowRating ? provider.review_count ?? undefined : undefined,
      priceRange,
    }),
  );
}

if (canShowRating && typeof provider.rating === 'number') {
  jsonLd.push({
    '@context': 'https://schema.org',
    '@type': 'Review',
    itemReviewed: {
      '@type': 'Organization',
      name: displayName,
    },
    author: {
      '@type': 'Organization',
      name: 'ProxyFAQs',
    },
    reviewRating: {
      '@type': 'Rating',
      ratingValue: provider.rating,
      bestRating: 5,
    },
    reviewBody: pageDescription,
  });
}

const websiteHostname = provider.website_url
  ? (() => {
      try {
        return new URL(provider.website_url).hostname;
      } catch {
        return provider.website_url.replace(/^https?:\/\//, "");
      }
    })()
  : null;
---

<Base
  title={`${displayName} Review and Fit Check`}
  description={pageDescription}
  canonicalUrl={pageUrl}
  noindex={shouldNoindex}
  jsonLd={jsonLd}
  ogType="product"
>
  <article class="py-8 md:py-12">
    <div class="container-custom">
      <!-- Breadcrumbs -->
      <nav class="mb-6" aria-label="Breadcrumb">
        <ol class="flex items-center gap-2 text-sm text-secondary-500">
          <li>
            <a href="/" class="hover:text-primary-600">Home</a>
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"
              ></path>
            </svg>
            <a href="/providers" class="hover:text-primary-600">Providers</a>
          </li>
          <li class="flex items-center gap-2">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"
              ></path>
            </svg>
            <span class="text-secondary-900">{displayName}</span>
          </li>
        </ol>
      </nav>

      <!-- Affiliate Disclosure Banner -->
      {hasAffiliateLink && <AffiliateDisclosure variant="banner" />}

      <div class="grid lg:grid-cols-3 gap-8">
        <!-- Main Content -->
        <main class="lg:col-span-2">
          <!-- Header Card -->
          <div class="card mb-8">
            <div class="flex flex-col md:flex-row md:items-center gap-6">
              <!-- Logo -->
              <div class="flex-shrink-0">
                {provider.logo_url ? (
                  <img
                    src={provider.logo_url}
                    alt={`${provider.name} logo`}
                    class="w-24 h-24 rounded-xl object-contain bg-white border border-secondary-200 p-2"
                    width="96"
                    height="96"
                    decoding="async"
                  />
                ) : (
                  <div class="w-24 h-24 rounded-xl bg-primary-100 flex items-center justify-center">
                    <span class="text-primary-600 font-bold text-3xl">
                      {provider.name.charAt(0)}
                    </span>
                  </div>
                )}
              </div>

              <!-- Info -->
              <div class="flex-1">
                <div class="flex items-center gap-3 mb-2">
                  {
                    provider.rank && canShowRating && (
                      <span class="bg-primary-600 text-white text-sm font-bold px-3 py-1 rounded-full">
                        #{provider.rank} Provider
                      </span>
                    )
                  }
                </div>

                <h1 class="text-2xl md:text-3xl font-bold text-secondary-900 mb-2">
                  {displayName} review and fit check
                </h1>

                {
                  displayName !== provider.name && (
                    <p class="text-sm text-secondary-500 mb-2">
                      Listed in the current database as {provider.name}. This page uses the latest brand-safe naming available in the local research layer.
                    </p>
                  )
                }

                {/* Rating */}
                {
                  canShowRating && provider.rating && (
                    <div class="flex items-center gap-2 mb-3">
                      <div class="flex items-center gap-1">
                        {[...Array(5)].map((_, i) => (
                          <svg
                            class:list={[
                              'w-5 h-5',
                              i < stars ? 'text-yellow-400' : 'text-secondary-300',
                            ]}
                            fill="currentColor"
                            viewBox="0 0 20 20"
                          >
                            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                          </svg>
                        ))}
                      </div>
                      <span class="text-lg font-semibold text-secondary-900">
                        {provider.rating.toFixed(1)}
                      </span>
                      <span class="text-secondary-500">/ 5</span>
                    </div>
                  )
                }

                <p class="text-secondary-600">{pageDescription}</p>

                <div class="mt-5 grid gap-3 sm:grid-cols-3 text-sm">
                  <a href="#fit" class="rounded-lg border border-primary-200 bg-primary-50 px-3 py-2 font-medium text-primary-700 hover:border-primary-300">
                    Check fit
                  </a>
                  <a href="#verify" class="rounded-lg border border-secondary-200 bg-secondary-50 px-3 py-2 font-medium text-secondary-700 hover:border-primary-300 hover:text-primary-700">
                    Verify risks
                  </a>
                  <a href="#compare" class="rounded-lg border border-secondary-200 bg-secondary-50 px-3 py-2 font-medium text-secondary-700 hover:border-primary-300 hover:text-primary-700">
                    Compare next
                  </a>
                </div>
              </div>
            </div>

            <!-- CTA Buttons -->
            <div class="flex flex-wrap gap-4 mt-6 pt-6 border-t border-secondary-200">
              {
                provider.affiliate_url && (
                  <a
                    href={provider.affiliate_url}
                    target="_blank"
                    rel="noopener sponsored"
                    class="btn-primary"
                  >
                    Visit {displayName}
                    <svg class="w-4 h-4 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
                      />
                    </svg>
                  </a>
                )
              }
              {
                provider.website_url && (
                  <a
                    href={provider.website_url}
                    target="_blank"
                    rel="noopener"
                    class="btn-secondary"
                  >
                    Official Website
                  </a>
                )
              }
            </div>
          </div>

          {
            editorial && (
              <>
                <div class="grid md:grid-cols-2 gap-6 mb-8">
                  <div class="card">
                    <h2 id="fit" class="text-xl font-semibold text-secondary-900 mb-4">Where this provider fits</h2>
                    <ul class="space-y-3 text-secondary-700">
                      {editorial.bestFor.map((item) => (
                        <li class="flex items-start gap-2">
                          <span class="text-primary-600 mt-1">•</span>
                          <span>{item}</span>
                        </li>
                      ))}
                    </ul>
                  </div>

                  <div class="card">
                    <h2 id="verify" class="text-xl font-semibold text-secondary-900 mb-4">What to verify before buying</h2>
                    <ul class="space-y-3 text-secondary-700">
                      {editorial.watchouts.map((item) => (
                        <li class="flex items-start gap-2">
                          <span class="text-primary-600 mt-1">•</span>
                          <span>{item}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                </div>

                <div class="card mb-8">
                  <h2 class="text-xl font-semibold text-secondary-900 mb-4">Research-backed notes</h2>
                  <p class="text-secondary-600 mb-4">
                    Reviewed against {editorial.sourceLabel.toLowerCase()} on {editorial.lastReviewed}. This section is intended to replace generic provider copy with merchant-safe fit notes and dated evidence.
                  </p>
                  <ul class="space-y-3 text-secondary-700">
                    {editorial.proofPoints.map((item) => (
                      <li class="flex items-start gap-2">
                        <span class="text-primary-600 mt-1">•</span>
                        <span>{item}</span>
                      </li>
                    ))}
                  </ul>
                  {editorial.pricingNote && <p class="text-sm text-secondary-500 mt-4">{editorial.pricingNote}</p>}
                </div>
              </>
            )
          }

          <!-- Pros & Cons -->
          <div class="grid md:grid-cols-2 gap-6 mb-8">
            {
              providerPros.length > 0 && (
                <div class="card">
                  <h2 class="flex items-center gap-2 text-lg font-semibold text-green-700 mb-4">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
                      />
                    </svg>
                    Pros
                  </h2>
                  <ul class="space-y-3">
                    {providerPros.map((pro) => (
                      <li class="flex items-start gap-2 text-secondary-700">
                        <svg
                          class="w-5 h-5 text-green-500 flex-shrink-0 mt-0.5"
                          fill="none"
                          stroke="currentColor"
                          viewBox="0 0 24 24"
                        >
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M5 13l4 4L19 7"
                          />
                        </svg>
                        {pro}
                      </li>
                    ))}
                  </ul>
                </div>
              )
            }

            {
              providerCons.length > 0 && (
                <div class="card">
                  <h2 class="flex items-center gap-2 text-lg font-semibold text-red-700 mb-4">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"
                      />
                    </svg>
                    Cons
                  </h2>
                  <ul class="space-y-3">
                    {providerCons.map((con) => (
                      <li class="flex items-start gap-2 text-secondary-700">
                        <svg
                          class="w-5 h-5 text-red-500 flex-shrink-0 mt-0.5"
                          fill="none"
                          stroke="currentColor"
                          viewBox="0 0 24 24"
                        >
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            stroke-width="2"
                            d="M6 18L18 6M6 6l12 12"
                          />
                        </svg>
                        {con}
                      </li>
                    ))}
                  </ul>
                </div>
              )
            }
          </div>

          <!-- Features -->
          {
            provider.features && Object.keys(provider.features).length > 0 && (
              <div class="card mb-8">
                <h2 class="text-xl font-semibold text-secondary-900 mb-4">Features</h2>
                <div class="grid sm:grid-cols-2 gap-4">
                  {Object.entries(provider.features).map(([key, value]) => (
                    <div class="flex items-start gap-3 p-3 rounded-lg bg-secondary-50">
                      <svg
                        class="w-5 h-5 text-primary-500 flex-shrink-0 mt-0.5"
                        fill="none"
                        stroke="currentColor"
                        viewBox="0 0 24 24"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          stroke-width="2"
                          d="M5 13l4 4L19 7"
                        />
                      </svg>
                      <div>
                        <span class="font-medium text-secondary-900">{key}</span>
                        {typeof value === 'string' && value !== 'true' && (
                          <span class="text-secondary-600 ml-2">{value}</span>
                        )}
                      </div>
                    </div>
                  ))}
                </div>
              </div>
            )
          }

          <div class="card mb-8">
            <h2 id="compare" class="text-xl font-semibold text-secondary-900 mb-4">Continue comparing</h2>
            <div class="grid sm:grid-cols-2 gap-3 text-sm">
              <a
                href="/guides/provider-comparison"
                class="rounded-lg border border-secondary-200 bg-secondary-50 px-4 py-3 text-secondary-700 hover:border-primary-300 hover:text-primary-700"
              >
                Read the provider comparison guide
              </a>
              <a
                href="/guides/choosing-proxy-type"
                class="rounded-lg border border-secondary-200 bg-secondary-50 px-4 py-3 text-secondary-700 hover:border-primary-300 hover:text-primary-700"
              >
                Match proxy type to workload
              </a>
              <a
                href="/use-cases"
                class="rounded-lg border border-secondary-200 bg-secondary-50 px-4 py-3 text-secondary-700 hover:border-primary-300 hover:text-primary-700"
              >
                Browse target-specific use cases
              </a>
              {
                (editorial?.slug === 'bright-data' || editorial?.slug === 'apify') && (
                  <a
                    href="/guides/bright-data-vs-apify-for-scraping"
                    class="rounded-lg border border-secondary-200 bg-secondary-50 px-4 py-3 text-secondary-700 hover:border-primary-300 hover:text-primary-700"
                  >
                    Compare Bright Data vs Apify
                  </a>
                )
              }
            </div>
          </div>

          <!-- Review Content -->
          {
            hasReviewHtml && (
              <div class="card">
                <h2 class="text-xl font-semibold text-secondary-900 mb-4">Full Review</h2>
                <div class="prose-custom" set:html={provider.review_html} />
              </div>
            )
          }
        </main>

        <!-- Sidebar -->
        <aside class="lg:col-span-1">
          <div class="sticky top-24 space-y-6">
            <!-- Quick Info -->
            <div class="card">
              <h2 class="font-semibold text-secondary-900 mb-4">Quick Info</h2>
              <dl class="space-y-3 text-sm">
                {provider.website_url && websiteHostname && (
                  <div class="flex justify-between">
                    <dt class="text-secondary-500">Website</dt>
                    <dd>
                      <a href={provider.website_url} target="_blank" rel="noopener" class="text-primary-600 hover:underline">
                        {websiteHostname}
                      </a>
                    </dd>
                  </div>
                )}
                {priceRange && (
                  <div class="flex justify-between">
                    <dt class="text-secondary-500">Starting From</dt>
                    <dd class="font-medium text-secondary-900">
                      {priceRange}
                    </dd>
                  </div>
                )}
                {editorial && (
                  <div class="flex justify-between gap-4">
                    <dt class="text-secondary-500">Research updated</dt>
                    <dd class="text-right text-secondary-900">{editorial.lastReviewed}</dd>
                  </div>
                )}
                {editorial && (
                  <div class="pt-2 border-t border-secondary-100">
                    <dt class="text-secondary-500 mb-1">Evidence source</dt>
                    <dd class="text-secondary-700">{editorial.sourceLabel}</dd>
                  </div>
                )}
              </dl>
            </div>

            <!-- Other Providers -->
            <div class="card">
              <h2 class="font-semibold text-secondary-900 mb-4">Compare With</h2>
              <div class="space-y-3">
                {otherProviders.map((other) => (
                  <a
                    href={`/providers/${other.slug}`}
                    class="flex items-center gap-3 p-2 rounded-lg hover:bg-secondary-50 transition-colors"
                  >
                    {other.logo_url ? (
                      <img
                        src={other.logo_url}
                        alt={other.name}
                        class="w-8 h-8 rounded object-contain"
                        width="32"
                        height="32"
                        loading="lazy"
                        decoding="async"
                      />
                    ) : (
                      <div class="w-8 h-8 rounded bg-primary-100 flex items-center justify-center">
                        <span class="text-primary-600 font-bold text-sm">{other.name.charAt(0)}</span>
                      </div>
                    )}
                    <span class="text-secondary-700 hover:text-primary-600">{getProviderDisplayName(other)}</span>
                  </a>
                ))}
              </div>
            </div>

            <!-- Affiliate Note -->
            {hasAffiliateLink && <AffiliateDisclosure variant="sidebar" />}
          </div>
        </aside>
      </div>
    </div>
  </article>
</Base>
