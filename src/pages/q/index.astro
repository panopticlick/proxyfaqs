---
export const prerender = true;

import Base from '../../layouts/Base.astro';
import SearchBox from '../../components/SearchBox.astro';
import QuestionCard from '../../components/QuestionCard.astro';
import { assertBuildDataNonEmpty, handleBuildDataError } from '../../lib/build-data';
import { getPopularQuestions, getCategories } from '../../lib/supabase';
import { env } from '../../lib/env';

let questions: any[] = [];
let categories: any[] = [];

try {
  [questions, categories] = await Promise.all([getPopularQuestions(50), getCategories()]);
} catch (error) {
  handleBuildDataError('questions index data fetch', error);
}

assertBuildDataNonEmpty('questions index popular questions', questions.length);
assertBuildDataNonEmpty('questions index categories', categories.length);

const siteUrl = env.SITE;
const pageUrl = `${siteUrl}/q`;
---

<Base
  title="Proxy Question Finder"
  description="Search practical proxy and web scraping answers, then browse popular questions by topic. Start with the search tool before reading the full Q&A archive."
  canonicalUrl={pageUrl}
>
  <div class="bg-secondary-50 min-h-screen">
    <!-- Tool-first Header -->
    <section class="bg-gradient-to-b from-primary-50 to-white border-b border-secondary-200 py-10 md:py-14">
      <div class="container-custom">
        <div class="max-w-3xl">
          <p class="badge-primary w-fit mb-4">Proxy Question Finder</p>
          <h1 class="text-3xl md:text-4xl font-bold text-secondary-900 mb-4">
            Find the proxy answer before you browse the archive
          </h1>
          <p class="text-lg text-secondary-600 mb-6">
            Search a proxy error, provider question, scraping workflow, or IP type. The page below is the fallback archive; the primary task is getting to one useful answer fast.
          </p>
          <div class="max-w-2xl">
            <SearchBox size="lg" autofocus placeholder="Search proxy questions, errors, providers, or scraping setups..." />
          </div>
          <div class="mt-5 flex flex-wrap gap-2 text-sm">
            <a href="/search?q=residential%20proxy" class="badge-secondary hover:text-primary-700">Residential proxy</a>
            <a href="/search?q=rotating%20proxy" class="badge-secondary hover:text-primary-700">Rotating proxy</a>
            <a href="/search?q=proxy%20blocked" class="badge-secondary hover:text-primary-700">Proxy blocked</a>
            <a href="/search?q=datacenter%20proxy" class="badge-secondary hover:text-primary-700">Datacenter proxy</a>
          </div>
        </div>
      </div>
    </section>

    <!-- Content -->
    <section class="py-8">
      <div class="container-custom">
        <div class="grid lg:grid-cols-4 gap-8">
          <!-- Sidebar - Categories -->
          <aside class="lg:col-span-1">
            <div class="sticky top-24">
              <h2 class="font-semibold text-secondary-900 mb-4">Categories</h2>
              <nav class="space-y-2">
                {
                  categories.slice(0, 15).map((category) => (
                    <a
                      href={`/category/${category.slug}`}
                      class="block px-3 py-2 rounded-lg text-sm text-secondary-600 hover:bg-white hover:text-primary-600 transition-colors"
                    >
                      {category.name}
                      <span class="text-secondary-400 ml-1">
                        ({category.question_count?.toLocaleString() || 0})
                      </span>
                    </a>
                  ))
                }
              </nav>
            </div>
          </aside>

          <!-- Main Content - Questions -->
          <main class="lg:col-span-3">
            <div class="mb-6">
              <h2 class="text-2xl font-bold text-secondary-900 mb-2">Popular proxy questions</h2>
              <p class="text-secondary-600">
                Browse {questions.length.toLocaleString()} high-traffic questions only after trying the finder above.
              </p>
            </div>

            <div class="grid gap-4">
              {questions.map((question) => <QuestionCard question={question} />)}
            </div>

            {
              questions.length === 0 && (
                <div class="text-center py-12">
                  <p class="text-secondary-600">No questions found.</p>
                </div>
              )
            }
          </main>
        </div>
      </div>
    </section>
  </div>
</Base>
